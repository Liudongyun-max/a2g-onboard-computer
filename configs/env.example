# Copy to configs/env.local and edit for the aircraft.
VISION_LANDING_CONFIG="/home/jetson/on-board computer/configs/aruco_live.yaml"
VISION_LANDING_CAMERA_CONFIG="/home/jetson/on-board computer/configs/camera.yaml"
PYTHONPATH="/home/jetson/on-board computer/src"
DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=8080

# Common MAVLink examples:
# udp:127.0.0.1:14550        PX4/ArduPilot SITL on localhost
# /dev/ttyTHS1,57600         Jetson UART to flight controller
# /dev/ttyUSB0,921600        USB telemetry adapter
MAVLINK_CONNECTION=udp:127.0.0.1:14550
