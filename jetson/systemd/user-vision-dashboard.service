[Unit]
Description=UAV Vision Landing Web Dashboard (User)
After=network-online.target

[Service]
Type=simple
Environment=DASHBOARD_HOST=0.0.0.0
Environment=DASHBOARD_PORT=8080
ExecStart=/bin/bash -lc 'cd "$HOME/on-board computer/jetson" && exec scripts/run_dashboard.sh'
Restart=on-failure
RestartSec=2

[Install]
WantedBy=default.target
