# Runtime logs
logs/*
**/logs/*
!logs/.gitkeep
!**/logs/.gitkeep

# Reports and probes
reports/*
**/reports/*
!reports/.gitkeep
!**/reports/.gitkeep

# Media captures
*.mjpg
*.mp4
*.avi
*.mov
*.mkv

# Local binaries and portable tools
tools/vlc/vlc-*/
**/tools/vlc/vlc-*/
*.exe
*.dll
*.zip
*.7z

# Windows local shortcuts
*.lnk
Thumbs.db
Desktop.ini

# Python / editor cache
__pycache__/
*.pyc
.venv/
.vscode/
.idea/
*.tmp
*.log

# OS metadata
.DS_Store
